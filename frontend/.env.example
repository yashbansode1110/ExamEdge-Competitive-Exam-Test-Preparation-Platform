# Backend URL (no trailing slash; do not append /api).
# In dev you can omit both and rely on the Vite proxy + VITE_DEV_BACKEND_URL below.
VITE_API_URL=http://127.0.0.1:4001
VITE_API_BASE_URL=http://127.0.0.1:4001

# Used only by Vite dev server to proxy /api, /auth, /tests, /analytics
VITE_DEV_BACKEND_URL=http://127.0.0.1:4001

